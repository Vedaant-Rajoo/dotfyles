#!/usr/bin/env fish
# Taken from: https://github.com/joshmedeski/dotfiles/blob/main/.config/bin/u

gum style \
    --foreground 12 --border-foreground 12 --border double \
    --margin "1 0" --padding "0 2" \
    '
‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ
‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
 ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
 '

set -l NOW (date +%Y-%m-%d-%H-%M-%S)
echo -e "$NOW\n" >>/tmp/u-$NOW.txt

if not gum confirm "Do you wish to update your scripts?"
    exit 1
end

gum spin --spinner globe --title "ūü™ü tpm plugins updating..." --show-output -- ~/.config/tmux/plugins/tpm/bin/update_plugins all >>/tmp/u-$NOW.txt
echo "" >>/tmp/u-$NOW.txt
echo "‚úÖ ūü™ü tpm plugins updated"

gum spin --spinner globe --title "ūüí§ lazy.nvim syncing..." -- nvim --headless "+Lazy! sync" +qa
echo "" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüí§ lazy.nvim synced"

gum spin --spinner globe --title "ūüßį mason.nvim updating" -- nvim --headless "+MasonUpdate" +qa
echo "" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüßį mason.nvim updated"

gum spin --spinner globe --title "ūüĆ≥ nvim-treesitter updating" -- nvim --headless "+TSUpdate" +qa
echo "" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüĆ≥ nvim-treesitter updated"

gum spin --spinner globe --title "ūüćĽ brew updating" --show-output -- brew update >>/tmp/u-$NOW.txt
echo "" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüćĽ brew updated"

set -l OUTDATED (brew outdated)
echo $OUTDATED >>/tmp/u-$NOW.txt

if test -n "$OUTDATED"
    gum spin --spinner globe --title "ūüćĽ brew upgrading" --show-output -- brew upgrade >>/tmp/u-$NOW.txt
    echo "" >>/tmp/u-$NOW.txt
    echo "‚úÖ ūüćĽ brew upgraded"

    gum spin --spinner globe --title "ūüćĽ brew cleaning up" --show-output -- brew cleanup --prune=all >>/tmp/u-$NOW.txt
    echo "" >>/tmp/u-$NOW.txt
    echo "‚úÖ ūüćĽ brew cleaned up"
else
    echo "No outdated brew packages" >>/tmp/u-$NOW.txt
end

gum spin --spinner globe --title "ūüćĽ brew doctoring" --show-output -- brew doctor >>/tmp/u-$NOW.txt
echo "" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüćĽ brew doctored"

echo "‚úÖ ūüßĺ logged to /tmp/u-$NOW.txt"
bat /tmp/u-$NOW.txt
